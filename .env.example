# ── Polymarket auth ─────────────────────────────────────────────────────────
# Ethereum private key (64 hex chars, no 0x prefix)
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLYMARKET_CHAIN_ID=137

# L2 API credentials — derived once via: python -c "from polymarket_client import *; c = PolymarketClient('YOUR_KEY'); print(c.derive_api_key())"
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# ── Bot config ───────────────────────────────────────────────────────────────
POLYMARKET_WHALE_TOP_N=20
POLYMARKET_POSITION_PCT=0.02
POLYMARKET_MAX_TRADES_PER_DAY=10
POLYMARKET_MIN_WIN_RATE=0.55
POLYMARKET_MIN_TRADE_COUNT=50
POLYMARKET_MIN_AVG_SIZE_USDC=500
POLYMARKET_MIN_LIQUIDITY=10000
POLYMARKET_PROFIT_TARGET_PCT=0.25
POLYMARKET_WHALE_SHRINK_THRESH=0.30
POLYMARKET_HOURS_BEFORE_CLOSE=72
